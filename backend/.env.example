# Fillosophy — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Claude API (required for real extractions)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI mock mode: "true" = free/offline fake responses, "false" = real Claude API
# Set to "true" during development to avoid API costs entirely
MOCK_AI=false

# Database backend: "sqlite" (default) or "supabase"
DB_BACKEND=sqlite

# Required only when DB_BACKEND=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key_here
